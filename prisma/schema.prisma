generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  MENTOR
  PARENT
  ADMIN
  SCHOOL_ADMIN
}

enum Pathway {
  CODING_AI
  ROBOTICS
  IOT
}

enum LessonType {
  VIDEO
  READING
  LAB
  QUIZ
  PROJECT
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  RETURNED
}

enum EnrollmentStatus {
  PENDING_PAYMENT
  ACTIVE
  INSTITUTIONAL
  CANCELLED
}

enum PaymentMethod {
  STRIPE
  CREDIT_CARD
  WIRE_TRANSFER
  ZELLE
  VENMO
  PAYPAL
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PartnershipStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CertificateStatus {
  VALID
  REVOKED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          Role      @default(STUDENT)
  schoolId      String?
  school        School?   @relation(fields: [schoolId], references: [id])
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  enrollments   Enrollment[]
  payments      Payment[]
  progress      LessonProgress[]
  submissions   Submission[]
  experienceProgress ExperienceProgress[]
  taughtCourses Course[]  @relation("CourseMentor")
  accounts      Account[]
  sessions      Session[]
  studentProfile StudentProfile?
  certificates   Certificate[]
  assessmentAttempts CourseAssessmentAttempt[]
}

model StudentProfile {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  middleName               String?
  dateOfBirth              DateTime
  phone                    String
  gender                   String?
  streetAddress            String
  city                     String
  stateProvince            String
  country                  String
  postalCode               String
  emergencyContactName     String
  emergencyContactPhone    String
  emergencyContactRelation String
  guardianName             String
  guardianEmail            String
  guardianPhone            String
  currentSchoolName        String
  gradeLevel               String
  graduationYear           String
  preferredLanguage        String   @default("en")
  howHeardAboutNova        String?
  termsAcceptedAt          DateTime
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model School {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  city      String?
  state     String?
  createdAt DateTime @default(now())

  users       User[]
  courses     Course[]
  partnership PartnershipApplication?
}

model Course {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String
  pathway     Pathway
  level       String    @default("Beginner")
  thumbnail   String?
  published   Boolean   @default(false)
  mentorId    String?
  mentor      User?     @relation("CourseMentor", fields: [mentorId], references: [id])
  schoolId    String?
  school      School?   @relation(fields: [schoolId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  modules     Module[]
  enrollments Enrollment[]
  assignments Assignment[]
  product     CourseProduct?
  payments    Payment[]
  certificates Certificate[]
  assessmentAttempts CourseAssessmentAttempt[]
}

model Module {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  lessons     Lesson[]
}

model Lesson {
  id          String     @id @default(cuid())
  title       String
  content     String
  type        LessonType @default(READING)
  videoUrl    String?
  duration    Int        @default(15)
  order       Int
  moduleId    String
  module      Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())

  progress    LessonProgress[]
}

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status      EnrollmentStatus @default(PENDING_PAYMENT)
  paymentId   String?          @unique
  payment     Payment?         @relation(fields: [paymentId], references: [id])
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  certificate Certificate?

  @@unique([userId, courseId])
}

model CourseAssessmentAttempt {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId      String
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attemptNumber Int
  scorePercent  Int
  passed        Boolean
  createdAt     DateTime @default(now())

  @@unique([userId, courseId, attemptNumber])
}

model Certificate {
  id           String            @id @default(cuid())
  code         String            @unique
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId     String
  course       Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollmentId String?           @unique
  enrollment   Enrollment?       @relation(fields: [enrollmentId], references: [id])
  holderName   String
  programTitle String
  programSlug  String
  scorePercent Int
  prefix       String            @default("NOVA-CERT")
  locale       String            @default("en")
  status       CertificateStatus @default(VALID)
  issuedAt     DateTime          @default(now())
}

model CourseProduct {
  id            String   @id @default(cuid())
  courseId      String   @unique
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  priceCents    Int
  currency      String   @default("usd")
  stripePriceId String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  amountCents     Int
  currency        String        @default("usd")
  method          PaymentMethod @default(STRIPE)
  status          PaymentStatus @default(PENDING)
  stripeSessionId String?       @unique
  stripePaymentId String?
  notes           String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  enrollment Enrollment?
}

model PartnershipApplication {
  id                     String            @id @default(cuid())
  institutionName        String
  legalName              String?
  institutionType        String
  website                String?
  taxId                  String?
  yearEstablished        String?
  streetAddress          String?
  stateProvince          String?
  postalCode             String?
  contactName            String
  contactRole            String
  email                  String
  phone                  String?
  billingContactName     String?
  billingEmail           String?
  billingPhone           String?
  decisionMakerName      String?
  decisionMakerTitle     String?
  decisionMakerEmail     String?
  country                String
  city                   String
  productInterest        String
  estimatedStudents      Int
  studentAgeRange        String?
  targetLaunchDate       String?
  contractTerm           String?
  budgetRange            String?
  currentStemOfferings   String?
  hardwareInfrastructure String?
  message                String
  locale                 String            @default("en")
  status                 PartnershipStatus @default(PENDING)
  paymentMethod          PaymentMethod?
  paymentStatus          PaymentStatus     @default(PENDING)
  paymentNotes           String?
  termsAcceptedAt        DateTime?
  schoolId               String?           @unique
  school                 School?           @relation(fields: [schoolId], references: [id])
  reviewedAt             DateTime?
  reviewedBy             String?
  submittedAt            DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed   Boolean   @default(false)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([userId, lessonId])
}

model Assignment {
  id          String   @id @default(cuid())
  title       String
  description String
  dueDate     DateTime?
  maxScore    Int      @default(100)
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  submissions Submission[]
}

model Submission {
  id           String           @id @default(cuid())
  content      String
  status       SubmissionStatus @default(DRAFT)
  score        Int?
  feedback     String?
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignmentId String
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  submittedAt  DateTime?
  reviewedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([userId, assignmentId])
}

// Auth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ExperienceProgress {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  experienceSlug String
  buddyId        String?
  buddyNickname  String?
  currentStage   Int       @default(0)
  labComplete    Boolean   @default(false)
  quizComplete   Boolean   @default(false)
  reflection     String?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, experienceSlug])
}
