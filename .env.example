# Database (SQLite for local dev, PostgreSQL for production on Vercel)
DATABASE_URL="file:./dev.db"

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-32-char-secret"

# App URL
NEXTAUTH_URL="http://localhost:3000"

# Public site URL — keep Vercel until DNS cutover, then set:
# NEXT_PUBLIC_SITE_URL="https://novastemhub.education"
NEXT_PUBLIC_SITE_URL="https://stem-innovation-academy.vercel.app"

# When domain is live, also set:
# NEXTAUTH_URL="https://novastemhub.education"

# Stripe (optional — kept for institutional partnership card checkout; student B2C is PayPal-only)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# PayPal (student checkout — manual Friends & Family / Send Money; no API secret required)
# Show this email / paypal.me link on the enroll checkout screen:
# NEXT_PUBLIC_PAYPAL_EMAIL="payments@yourdomain.com"
# NEXT_PUBLIC_PAYPAL_ME="https://paypal.me/YourHandle"

# Admin notify when a student creates a PENDING PayPal payment (Resend)
# Create an API key at https://resend.com — never commit real keys.
# RESEND_API_KEY="re_..."
# ADMIN_NOTIFY_EMAIL="admin@yourdomain.com"
# Optional alias if ADMIN_NOTIFY_EMAIL is unset:
# ADMIN_EMAIL="admin@yourdomain.com"
# Optional From (verified domain in Resend). Defaults to Resend onboarding sender:
# EMAIL_FROM="NOVA Academy <payments@yourdomain.com>"

# Sitewide course sale (list prices stay in catalog; charge = list × (100 - percent) / 100)
# NEXT_PUBLIC_COURSE_DISCOUNT_PERCENT="50"
# Set to "0" to disable the sale display and charge full list price.

# Google Analytics 4 — add after domain is live (e.g. G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Google Search Console verification (optional, after domain is live)
# GOOGLE_SITE_VERIFICATION="your-google-verification-code"

# Gemini API (optional — server-only test integration for Órbita AI Tutoring)
# Create a key in Google AI Studio. Never prefix this with NEXT_PUBLIC_.
# GEMINI_API_KEY="your-google-ai-studio-key"

# NOVA AI Tutoring classroom release switch — OFF by default for public safety.
# Set to "true" only in your local .env to test /ai-tutoring and /ai-tutoring/session.
NEXT_PUBLIC_NOVA_AI_TUTORING_ENABLED="false"
