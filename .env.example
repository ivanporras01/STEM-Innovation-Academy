# Database (SQLite for local dev, PostgreSQL for production on Vercel)
DATABASE_URL="file:./dev.db"

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-32-char-secret"

# App URL
NEXTAUTH_URL="http://localhost:3000"

# Public site URL — set to https://novastemhub.education when domain + hosting are live
NEXT_PUBLIC_SITE_URL="https://stem-innovation-academy.vercel.app"

# Stripe (optional — card checkout; without these, demo checkout + Zelle/Venmo/Other work)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Google Analytics 4 — add after domain is live (e.g. G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Google Search Console verification (optional, after domain is live)
# GOOGLE_SITE_VERIFICATION="your-google-verification-code"

# Gemini API (optional — server-only test integration for Órbita AI Tutoring)
# Create a key in Google AI Studio. Never prefix this with NEXT_PUBLIC_.
# GEMINI_API_KEY="your-google-ai-studio-key"

# NOVA AI Tutoring classroom release switch — OFF by default for public safety.
# Set to "true" only in your local .env to test /ai-tutoring and /ai-tutoring/session.
NEXT_PUBLIC_NOVA_AI_TUTORING_ENABLED="false"
