{
  "name": "nova-lms",
  "version": "1.0.0",
  "private": true,
  "description": "NOVA Academy — STEM Innovation Academy LMS (NOVA STEM HUB K-12)",
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma generate && prisma db push && tsx prisma/seed.ts",
    "test:ai-tutoring-graph": "tsx scripts/test-ai-tutoring-graph.ts",
    "test:ai-tutoring-quality": "tsx scripts/test-ai-tutoring-quality.ts",
    "catalog:pdf": "tsx scripts/generate-catalog-pdf.ts",
    "cert:sample-pdf": "tsx scripts/generate-certificate-sample-pdf.ts",
    "vercel-build": "node scripts/prepare-vercel-build.mjs && prisma generate && prisma db push --skip-generate --accept-data-loss && tsx prisma/seed.ts && next build",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "next": "^15.1.0",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^22.3.2",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "prisma": "^6.1.0",
    "puppeteer": "^25.3.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
